# --- API ---
NODE_ENV=development
APP_PORT=3001

# Base de dados (dev local: Postgres no host; Docker Compose: ver bloco abaixo)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=

# Segurança (gere valores fortes; nunca commits isto no Git)
JWT_SECRET=
# Custo bcrypt (número de rounds). Alias legado: CRYPT_SAULT
CRYPT_SALT=10

# Swagger em /api e /api-json — HTTP Basic Auth
SWAGGER_USER=admin
SWAGGER_PASSWORD=

# Obsoleto: ignorado pela app (use só migrations)
# DB_SYNCHRONIZE=true

# --- Docker Compose (Postgres + API + Nginx): `docker compose up -d` ---
#
# Superuser do contentor (init + emergência). Não reutilizar como DB_USER.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=task_hive
#
# Utilizador da API (migrations e runtime). Tem de ser != POSTGRES_USER.
# Não deixes vazio: o cliente Node (SCRAM) exige password em string.
DB_USER=taskhive_app
DB_PASSWORD=
#
# Utilizador para pgAdmin / psql / DBeaver a partir da LAN (host:POSTGRES_PUBLISH_PORT).
DB_REMOTE_USER=taskhive_remote
DB_REMOTE_PASSWORD=
#
# Com a API no Compose, DB_HOST/DB_PORT são forçados para postgres:5432; no .env define:
DB_NAME=task_hive
#
# Porta Postgres no *host* (ligação remota: IP-da-máquina:esta-porta). Dentro do Compose a API usa sempre postgres:5432.
# Se já tens Postgres (ou outro serviço) na 5432 no sistema, usa outra (ex. 5433) para evitar erro de bind.
# Protege com firewall se expuseres à Internet.
POSTGRES_PUBLISH_PORT=5432

# --- Docker Compose: porta HTTP no host (Nginx → API) ---
HTTP_PORT=8080
