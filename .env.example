# --- API ---
NODE_ENV=development
APP_PORT=3001

# --- Base de dados (define UMA vez DB_USER / DB_PASSWORD / DB_NAME; não dupliques no ficheiro) ---
# Dev local (`npm run start:dev`): DB_HOST=127.0.0.1 e DB_PORT do Postgres no host.
# Docker Compose: o compose força na API DB_HOST=postgres e DB_PORT=5432 (ignora DB_HOST do .env no contentor).
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=taskhive_app
# Obrigatório e não vazio (Node/pg SCRAM). Se tiver # ou espaços, usa aspas: DB_PASSWORD="segredo#1"
DB_PASSWORD=
DB_NAME=task_hive

# Segurança (gere valores fortes; nunca commits isto no Git)
JWT_SECRET=
# Se o JWT_SECRET tiver $ e usares variáveis no docker-compose.yml, escapa no .env como $$ (ver documentação Docker Compose).
# Custo bcrypt (número de rounds). Alias legado: CRYPT_SAULT
CRYPT_SALT=10

# Swagger em /api e /api-json — HTTP Basic Auth
SWAGGER_USER=admin
SWAGGER_PASSWORD=

# Obsoleto: ignorado pela app (use só migrations)
# DB_SYNCHRONIZE=true

# --- Seeder admin (uma vez; não commits a password) ---
# npm run seed:admin — obrigatório. Nome/email: git config user.name / user.email ou:
SEED_ADMIN_NAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# --- Docker Compose (Postgres + API + Nginx): `docker compose up -d` ---
#
# Superuser do contentor (init + emergência). Não reutilizar como DB_USER.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=task_hive
#
# Utilizador remoto (pgAdmin, etc.): host:POSTGRES_PUBLISH_PORT
DB_REMOTE_USER=taskhive_remote
DB_REMOTE_PASSWORD=
#
# Porta Postgres no *host* (ligação remota: IP-da-máquina:esta-porta). Dentro do Compose a API usa sempre postgres:5432.
# Se já tens Postgres na 5432 no sistema, usa outra (ex. 5433) para evitar erro de bind.
# Protege com firewall se expuseres à Internet.
POSTGRES_PUBLISH_PORT=5432

# --- Docker Compose: porta HTTP no host (Nginx → API) ---
HTTP_PORT=8080
