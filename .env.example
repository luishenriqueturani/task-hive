# --- API ---
NODE_ENV=development
APP_PORT=3001

# Base de dados (Postgres no host ou noutro servidor)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=

# Segurança (gere valores fortes; nunca commits isto no Git)
JWT_SECRET=
# Custo bcrypt (número de rounds). Alias legado: CRYPT_SAULT
CRYPT_SALT=10

# Swagger em /api e /api-json — HTTP Basic Auth
SWAGGER_USER=admin
SWAGGER_PASSWORD=

# Obsoleto: ignorado pela app (use só migrations)
# DB_SYNCHRONIZE=true

# --- Docker Compose: Postgres integrado (segundo ficheiro) ---
# docker-compose -f docker-compose.yml -f docker-compose.postgres.yml up -d
POSTGRES_USER=taskhive
POSTGRES_PASSWORD=
POSTGRES_DB=task_hive

# Com Postgres no Compose, a API dentro do Docker deve usar:
# DB_HOST=postgres
# DB_PORT=5432
# DB_USER=<igual a POSTGRES_USER>
# DB_PASSWORD=<igual a POSTGRES_PASSWORD>
# DB_NAME=<igual a POSTGRES_DB>

# --- Docker Compose: porta HTTP no host (Nginx → API) ---
HTTP_PORT=8080
