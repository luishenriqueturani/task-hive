# Copie para .env.e2e e ajuste se necessário.
# Suba o Postgres: docker compose -f docker-compose.e2e.yml up -d

NODE_ENV=test

DB_HOST=127.0.0.1
DB_PORT=5433
DB_USER=taskhive_e2e
DB_PASSWORD=taskhive_e2e_secret
DB_NAME=task_hive_e2e

# Segredos apenas para ambiente de teste local/CI
JWT_SECRET=e2e_jwt_secret_must_be_long_enough_for_hs256_abc123
# bcrypt cost (Crypt.hash usa esta variável — ver src/utils/crypt.ts)
CRYPT_SAULT=10

# Opcional para a app ao escutar; E2E usam porta efémera via listen(0)
APP_PORT=3099
